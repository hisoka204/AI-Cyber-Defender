# ═══════════════════════════════════════════════════════════════════════════════
# TENET AI - Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════════
#
# 📋 INSTRUCTIONS:
# 1. Copy this file to .env in the same directory
#    cp .env.template .env
# 2. Update the values according to your environment
# 3. Never commit the .env file to version control
# 4. Keep credentials secure and rotate them regularly
#
# 🔒 SECURITY BEST PRACTICES:
# - Use strong, unique passwords for all services
# - Change all default values before deploying to production
# - Enable DEBUG only in development environments
# - Use HTTPS in production (configure reverse proxy/load balancer)
# - Restrict CORS_ORIGINS to known domains only
# - Set appropriate rate limits based on your infrastructure
#
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# API CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# API authentication key (required)
# Include this in the 'X-API-Key' header for all API requests
# ⚠️ SECURITY: Generate a strong random key (min 32 characters)
# Example: openssl rand -hex 32
# 🔄 Rotate this key regularly (every 90 days recommended)
API_KEY=tenet-dev-key-change-in-production

# CORS allowed origins (comma-separated, no spaces after commas)
# Restricts which domains can make requests to your API
# Examples:
#   Development: http://localhost:3000,http://localhost:8080
#   Production: https://app.example.com,https://dashboard.example.com
#   All origins (NOT recommended for production): *
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ═══════════════════════════════════════════════════════════════════════════════
# INGEST SERVICE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# The ingest service receives and normalizes incoming security events and prompts

# Ingest service host binding
# Use 0.0.0.0 to accept connections from any interface (required for Docker)
# Use 127.0.0.1 to accept only local connections
INGEST_API_HOST=0.0.0.0

# Ingest service port
# Default: 8000. Ensure this port is not used by other services
INGEST_API_PORT=8000

# ═══════════════════════════════════════════════════════════════════════════════
# ANALYZER SERVICE CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# The analyzer service performs ML-based threat analysis on ingested data

# Analyzer service host binding
# Use 0.0.0.0 to accept connections from any interface (required for Docker)
# Use 127.0.0.1 to accept only local connections
ANALYZER_API_HOST=0.0.0.0

# Analyzer service port
# Default: 8100. Ensure this port is not used by other services
ANALYZER_API_PORT=8100

# Path to trained ML models (relative to project root or absolute)
# Expected structure:
#   models/trained/
#   ├── prompt_injection/
#   │   ├── model.pkl
#   │   └── config.json
#   ├── phishing/
#   ├── jailbreak/
#   └── ...
MODEL_PATH=./models/trained

# ═══════════════════════════════════════════════════════════════════════════════
# DETECTION THRESHOLDS
# ═══════════════════════════════════════════════════════════════════════════════
# All thresholds range from 0.0 to 1.0
# Higher values = fewer false positives, but might miss some threats
# Lower values = more sensitive detection, but more false positives

# Prompt injection detection threshold
# Detects attempts to manipulate AI behavior through crafted inputs
# Recommended: 0.75 (balanced), 0.85 (conservative), 0.65 (aggressive)
PROMPT_INJECTION_THRESHOLD=0.75

# Phishing detection threshold
# Identifies deceptive content designed to steal credentials or information
# Recommended: 0.85 (balanced), 0.90 (conservative), 0.75 (aggressive)
PHISHING_THRESHOLD=0.85

# Jailbreak detection threshold
# Detects attempts to bypass AI safety guardrails
# Recommended: 0.80 (balanced), 0.90 (conservative), 0.70 (aggressive)
JAILBREAK_THRESHOLD=0.80

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# Redis is used for caching, rate limiting, and session management

# Redis connection details
# For Docker: use service name from docker-compose.yml
# For local Redis: use localhost or 127.0.0.1
REDIS_HOST=localhost

# Redis port (default: 6379)
REDIS_PORT=6379

# Redis authentication password
# ⚠️ SECURITY: Must be set in production! Use a strong password (min 20 characters)
# Leave empty only for local development
# Example: openssl rand -base64 32
REDIS_PASSWORD=

# Redis database number (0-15)
# Use different numbers to isolate data between applications
REDIS_DB=0

# ═══════════════════════════════════════════════════════════════════════════════
# POSTGRESQL CONFIGURATION (for future use)
# ═══════════════════════════════════════════════════════════════════════════════
# PostgreSQL will store threat intelligence, detection logs, and analysis results

# PostgreSQL connection details
# For Docker: use service name from docker-compose.yml
# For local PostgreSQL: use localhost or 127.0.0.1
POSTGRES_HOST=localhost

# PostgreSQL port (default: 5432)
POSTGRES_PORT=5432

# Database name
# Will be created automatically on first run if it doesn't exist
POSTGRES_DB=tenet_ai

# Database user
POSTGRES_USER=postgres

# Database password
# ⚠️ SECURITY: Use a strong password in production (min 16 characters, mixed case, numbers, symbols)
# Example: openssl rand -base64 24
POSTGRES_PASSWORD=postgres

# ═══════════════════════════════════════════════════════════════════════════════
# MINIO CONFIGURATION (S3-compatible object storage)
# ═══════════════════════════════════════════════════════════════════════════════
# MinIO stores ML models, logs, and large binary artifacts

# MinIO server endpoint
# For Docker: use service name:port from docker-compose.yml
# For local MinIO: use localhost:9000
# Format: host:port (without http://)
MINIO_ENDPOINT=localhost:9000

# MinIO access credentials
# These act like AWS access key ID and secret access key
# ⚠️ SECURITY: Change defaults before production deployment
MINIO_ACCESS_KEY=minio

# ⚠️ SECURITY: Must be at least 8 characters. Use 32+ characters in production.
# Example: openssl rand -base64 32
MINIO_SECRET_KEY=minio123

# Default bucket for storing artifacts
# Will be created automatically on first run if it doesn't exist
# Bucket name must be lowercase, alphanumeric, and hyphens only
MINIO_BUCKET=tenet-ai

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Logging level
# Values: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Recommended: INFO (production), DEBUG (development)
# Note: DEBUG level can generate large log files
LOG_LEVEL=INFO

# Log output format
# Values: json, text
# 'json' is recommended for production (easier to parse and analyze)
# 'text' is more human-readable for development
LOG_FORMAT=text

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Rate limiting (requests per minute per API key)
# Prevents abuse and ensures fair resource allocation
# Lower values = stricter rate limiting, better protection against abuse
# Higher values = more permissive, better for high-traffic applications
# Recommended: 100-300 (production), 1000 (development/testing)
RATE_LIMIT_RPM=1000

# Maximum prompt length in characters
# Prevents resource exhaustion from excessively large inputs
# Recommended: 10000 (balanced), 5000 (conservative), 20000 (permissive)
# Note: Very large prompts increase processing time and memory usage
MAX_PROMPT_LENGTH=10000

# Enable/disable automatic threat blocking
# When true: Automatically blocks detected threats
# When false: Only logs threats for review (monitoring mode)
# ⚠️ CAUTION: Test thoroughly before enabling in production to avoid false positive blocks
# Recommended: false (initial deployment), true (after tuning thresholds)
BLOCKING_ENABLED=true

# ═══════════════════════════════════════════════════════════════════════════════
# MONITORING CONFIGURATION (Prometheus/Grafana)
# ═══════════════════════════════════════════════════════════════════════════════

# Enable Prometheus metrics endpoint
# When true: Exposes metrics at /metrics endpoint for Prometheus scraping
# When false: Metrics collection is disabled
# Recommended: true (production), false (if not using monitoring)
METRICS_ENABLED=true

# Prometheus metrics port
# Port where the /metrics endpoint will be exposed
# Default: 9090 (standard Prometheus port)
# Ensure this port is accessible to your Prometheus server
METRICS_PORT=9090

# ═══════════════════════════════════════════════════════════════════════════════
# DEVELOPMENT SETTINGS
# ═══════════════════════════════════════════════════════════════════════════════

# Enable debug mode (verbose logging, detailed error messages, stack traces)
# ⚠️ SECURITY: NEVER enable debug mode in production! It exposes sensitive information.
# Recommended: false (production), true (development)
DEBUG=false

# Enable hot reload for development
# Automatically restarts services when code changes are detected
# Recommended: true (development), false (production)
# Note: Hot reload increases resource usage and is not suitable for production
HOT_RELOAD=true

# ═══════════════════════════════════════════════════════════════════════════════
# END OF CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
